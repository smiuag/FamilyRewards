# Supabase — obtén estos valores en: https://supabase.com/dashboard → proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clave de servicio (solo para scripts de servidor / seed, NUNCA exponerla al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Activa la protección de rutas por sesión.
# Mantener en "false" mientras se desarrolla el flujo de auth real.
# Cambiar a "true" cuando la pantalla de login/registro esté lista.
NEXT_PUBLIC_AUTH_ENABLED=false
